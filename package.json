{
  "name": "abrwebsite-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace frontend\" \"npm run dev --workspace backend\"",
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
